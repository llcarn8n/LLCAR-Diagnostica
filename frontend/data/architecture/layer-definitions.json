  "meta": {
    "title": "LLCAR Diagnostica — 8-Layer System Definitions",
    "version": "1.0",
    "description": "Defines the 8 visualization layers for the 3D diagnostic viewer. Each layer groups related automotive components and has a unique color, icon, and multilingual display name.",
    "total_layers": 8,
    "total_components": 1422,
    "source": "automotive-glossary-3d-components.json v3.1-3d",
    "created": "2026-02-27"
  },
  "naming_convention": {
    "format": "{component_snake_case}@{layer_id}",
    "separator": "@",
    "component_rules": [
      "English name only, snake_case",
      "Use first variant before '/' (e.g., 'bonnet / hood' -> 'bonnet')",
      "Remove parenthetical abbreviations (e.g., '(AT)' -> '')",
      "Remove special characters except alphanumeric and spaces",
      "Collapse whitespace to underscore",
      "All lowercase"
    ],
    "examples": [
      "intake_manifold@engine",
      "front_left_brake_caliper@brakes",
      "traction_battery@ev",
      "front_camera@sensors",
      "blower_motor@hvac",
      "door_handle@interior",
      "front_bumper@body",
      "differential@drivetrain"
    ]
  },
